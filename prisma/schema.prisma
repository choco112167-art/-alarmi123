generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notice {
  id              String   @id @default(cuid())
  sourceRegion    String
  sourceName      String
  title           String
  summary         String?
  contentText     String?
  originalUrl     String
  attachmentUrls  String[]
  publishedAt     DateTime?
  detectedAt      DateTime @default(now())
  deadline        DateTime?
  matchedKeywords String[]
  contentHash     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([title, sourceRegion, originalUrl])
  @@index([sourceRegion, publishedAt])
  @@index([detectedAt])
}

model Source {
  id        String   @id @default(cuid())
  region    String
  name      String
  url       String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([region, name])
}

model CrawlLog {
  id         String    @id @default(cuid())
  sourceName String
  status     String
  message    String?
  foundCount Int       @default(0)
  savedCount Int       @default(0)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([startedAt])
}
